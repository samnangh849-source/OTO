    4 function manageLicense(action, data) {
    5   const ss = SpreadsheetApp.getActiveSpreadsheet();
    6   let sheet = ss.getSheetByName(SHEET_NAME_LICENSES);
    7   if (!sheet) {
    8     sheet = ss.insertSheet(SHEET_NAME_LICENSES);
    9     sheet.appendRow(['key', 'status', 'expiry_date', 'created_at', 'note']);
   10   }
   11
   12   const rows = sheet.getDataRange().getValues();
   13   
   14   if (action === 'create') {
   15     sheet.appendRow([data.key, 'active', data.expiry_date, new Date(), data.note]);
   16     return { success: true };
   17   }
   18   
   19   if (action === 'validate') {
   20     for (let i = 1; i < rows.length; i++) {
   21       if (rows[i][0] === data.key && rows[i][1] === 'active') {
   22         return { success: true, license: { key: rows[i][0], expiry: rows[i][2] } };
   23       }
   24     }
   25     return { success: false, message: 'Invalid or expired license key' };
   26   }
   27   
   28   if (action === 'update_status') {
   29     for (let i = 1; i < rows.length; i++) {
   30       if (rows[i][0] === data.key) {
   31         sheet.getRange(i + 1, 2).setValue(data.status); // active, blocked, etc.
   32         return { success: true };
   33       }
   34     }
   35   }
   36   // អាចបន្ថែម action 'delete' ឬ 'list' តាមតម្រូវការ
